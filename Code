<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sports Wallboard</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #080808; color: white; font-family: Arial, sans-serif; min-height: 100vh; }

  .tabs {
    display: flex; gap: 6px; padding: 12px 16px;
    background: #111; border-bottom: 1px solid #222; overflow-x: auto;
  }
  .tab {
    padding: 8px 16px; border-radius: 8px; border: 1px solid #333;
    background: transparent; color: #777; cursor: pointer; font-size: 13px;
    white-space: nowrap; transition: all 0.15s; font-family: Arial, sans-serif;
  }
  .tab.active { background: #222; color: white; border-color: #555; }

  .view { display: none; height: calc(100vh - 53px); overflow-y: auto; }
  .view.active { display: block; }

  /* ── TV VIEW ── */
  #tv-view { background: #080808; height: calc(100vh - 53px); overflow: hidden; }
  .tv-grid { display: grid; height: 100%; gap: 1px; background: #111; }
  .tv-card {
    background: #080808; display: flex; flex-direction: column;
    align-items: center; justify-content: center; padding: 24px; position: relative;
  }
  .tv-league {
    position: absolute; top: 12px; left: 16px;
    font-size: 10px; letter-spacing: 2px; color: #333; text-transform: uppercase;
  }
  .tv-status {
    position: absolute; top: 12px; right: 16px;
    display: flex; align-items: center; gap: 6px;
    font-size: 11px; letter-spacing: 1px;
  }
  .live-dot {
    width: 7px; height: 7px; border-radius: 50%; background: #ff3c3c;
    animation: pulse 1.4s infinite;
  }
  .live-label { color: #ff3c3c; font-size: 11px; letter-spacing: 2px; }
  .tv-teams { width: 100%; max-width: 420px; }
  .tv-team {
    display: flex; justify-content: space-between; align-items: center;
    padding: 8px 0;
  }
  .tv-team-name { font-size: clamp(16px, 2.5vw, 36px); font-weight: 300; color: #aaa; }
  .tv-team-name.winner { font-weight: 700; color: white; }
  .tv-score { font-size: clamp(22px, 4vw, 56px); font-weight: 700; color: white; min-width: 50px; text-align: right; }
  .tv-score.faded { color: #444; }
  .tv-empty {
    display: flex; align-items: center; justify-content: center;
    height: 100%; flex-direction: column; gap: 12px;
  }
  .tv-empty-icon { font-size: 48px; opacity: 0.1; }
  .tv-empty-text { color: #333; font-size: 12px; letter-spacing: 3px; text-transform: uppercase; }

  /* ── PHONE VIEW ── */
  #phone-view { padding: 12px; background: #0e0e0e; }
  .sport-section { margin-bottom: 24px; }
  .sport-title {
    font-size: 11px; letter-spacing: 3px; color: #555; text-transform: uppercase;
    margin-bottom: 10px; padding-left: 4px;
  }
  .game-row {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 14px; margin-bottom: 6px; border-radius: 10px;
    background: #141414; border: 1px solid #1e1e1e; cursor: pointer;
    transition: all 0.15s;
  }
  .game-row:hover { background: #1a1a1a; }
  .game-row.selected { background: #1a1a1a; border-color: #444; }
  .checkbox {
    width: 22px; height: 22px; border-radius: 6px; flex-shrink: 0;
    background: transparent; border: 1.5px solid #333;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 700; transition: all 0.15s;
  }
  .checkbox.checked { background: white; border-color: white; color: black; }
  .game-info { flex: 1; min-width: 0; }
  .game-teams { font-size: 14px; font-weight: 500; color: #ddd; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .game-meta { font-size: 11px; color: #555; margin-top: 2px; }
  .game-score { text-align: right; flex-shrink: 0; }
  .score-value { font-size: 18px; font-weight: 700; color: white; }
  .score-time { font-size: 11px; color: #555; margin-top: 2px; }
  .score-live { color: #ff3c3c; display: flex; align-items: center; gap: 4px; justify-content: flex-end; }

  .bottom-bar {
    position: fixed; bottom: 0; left: 0; right: 0;
    background: #111; border-top: 1px solid #222;
    padding: 10px 16px; text-align: center;
    font-size: 11px; color: #444; letter-spacing: 1px; text-transform: uppercase;
  }
  #selected-count { color: #ff3c3c; font-weight: 700; }

  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.2} }
</style>
</head>
<body>

<!-- TABS -->
<div class="tabs">
  <button class="tab active" onclick="switchTab('phone')">📱 Controller</button>
  <button class="tab" onclick="switchTab('tv')">📺 TV-Ansicht</button>
</div>

<!-- PHONE VIEW -->
<div id="phone-view" class="view active" style="padding-bottom: 50px;">
  <div id="games-list"></div>
</div>

<!-- TV VIEW -->
<div id="tv-view" class="view">
  <div id="tv-content"></div>
</div>

<div class="bottom-bar">
  <span id="selected-count">0</span> Spiele auf dem TV
</div>

<script>
// ── SPIELDATEN ──────────────────────────────────────────────────────────────
const GAMES = [
  // Bundesliga
  { id:1, sport:"⚽ Bundesliga", home:"Bayern München", away:"Bor. Dortmund", homeScore:2, awayScore:1, status:"live", info:"67'" },
  { id:2, sport:"⚽ Bundesliga", home:"Bayer Leverkusen", away:"RB Leipzig",   homeScore:1, awayScore:1, status:"live", info:"34'" },
  { id:3, sport:"⚽ Bundesliga", home:"Eintracht Frankfurt", away:"Stuttgart", homeScore:null, awayScore:null, status:"upcoming", info:"18:30" },

  // Premier League
  { id:4, sport:"⚽ Premier League", home:"Arsenal", away:"Chelsea",     homeScore:3, awayScore:1, status:"finished", info:"Ende" },
  { id:5, sport:"⚽ Premier League", home:"Man City", away:"Liverpool",  homeScore:null, awayScore:null, status:"upcoming", info:"20:45" },

  // Champions League
  { id:6, sport:"⚽ Champions League", home:"Real Madrid", away:"FC Barcelona", homeScore:0, awayScore:0, status:"live", info:"23'" },

  // NBA
  { id:7, sport:"🏀 NBA", home:"LA Lakers", away:"Boston Celtics", homeScore:87, awayScore:92, status:"live", info:"Q3 4:22" },
  { id:8, sport:"🏀 NBA", home:"Golden State", away:"Phoenix Suns",  homeScore:110, awayScore:98, status:"finished", info:"Ende" },
  { id:9, sport:"🏀 NBA", home:"Miami Heat", away:"Chicago Bulls",   homeScore:null, awayScore:null, status:"upcoming", info:"21:00" },

  // NHL
  { id:10, sport:"🏒 NHL", home:"Toronto Maple Leafs", away:"Boston Bruins", homeScore:2, awayScore:3, status:"live", info:"3rd 8:11" },
  { id:11, sport:"🏒 NHL", home:"Edmonton Oilers",     away:"Vancouver",     homeScore:4, awayScore:1, status:"finished", info:"Ende" },

  // Tennis
  { id:12, sport:"🎾 Tennis ATP", home:"Djokovic N.", away:"Alcaraz C.", homeScore:"6-3, 4", awayScore:"2, 6", status:"live", info:"Set 3" },
];

// ── STATE ───────────────────────────────────────────────────────────────────
let selected = JSON.parse(localStorage.getItem('selected') || '[]');

function save() {
  localStorage.setItem('selected', JSON.stringify(selected));
  document.getElementById('selected-count').textContent = selected.length;
}

function toggle(id) {
  if (selected.includes(id)) {
    selected = selected.filter(x => x !== id);
  } else {
    selected.push(id);
  }
  save();
  renderPhone();
  renderTV();
}

// ── RENDER PHONE ─────────────────────────────────────────────────────────────
function renderPhone() {
  const groups = {};
  GAMES.forEach(g => {
    if (!groups[g.sport]) groups[g.sport] = [];
    groups[g.sport].push(g);
  });

  let html = '';
  for (const [sport, games] of Object.entries(groups)) {
    html += `<div class="sport-section">
      <div class="sport-title">${sport}</div>`;
    games.forEach(g => {
      const isSelected = selected.includes(g.id);
      const isLive = g.status === 'live';
      html += `
        <div class="game-row ${isSelected ? 'selected' : ''}" onclick="toggle(${g.id})">
          <div class="checkbox ${isSelected ? 'checked' : ''}">${isSelected ? '✓' : ''}</div>
          <div class="game-info">
            <div class="game-teams">${g.home} vs ${g.away}</div>
            <div class="game-meta">${g.sport}</div>
          </div>
          <div class="game-score">
            ${g.homeScore !== null
              ? `<div class="score-value">${g.homeScore} : ${g.awayScore}</div>`
              : `<div class="score-time">${g.info}</div>`
            }
            <div class="${isLive ? 'score-live' : 'score-time'}">
              ${isLive ? `<div class="live-dot"></div> ${g.info}` : g.status === 'finished' ? 'Ende' : 'Geplant'}
            </div>
          </div>
        </div>`;
    });
    html += '</div>';
  }

  document.getElementById('games-list').innerHTML = html;
}

// ── RENDER TV ────────────────────────────────────────────────────────────────
function renderTV() {
  const tvGames = GAMES.filter(g => selected.includes(g.id));
  const container = document.getElementById('tv-content');

  if (tvGames.length === 0) {
    container.style.height = '100%';
    container.innerHTML = `
      <div class="tv-empty">
        <div class="tv-empty-icon">📺</div>
        <div class="tv-empty-text">Wähle Spiele im Controller aus</div>
      </div>`;
    return;
  }

  const count = tvGames.length;
  const cols = count <= 1 ? 1 : count <= 2 ? 2 : count <= 4 ? 2 : count <= 6 ? 3 : 4;
  const rows = Math.ceil(count / cols);

  const grid = document.createElement('div');
  grid.className = 'tv-grid';
  grid.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
  grid.style.gridTemplateRows = `repeat(${rows}, 1fr)`;
  grid.style.height = '100%';

  tvGames.forEach(g => {
    const isLive = g.status === 'live';
    const isFinished = g.status === 'finished';
    const homeWon = isFinished && g.homeScore > g.awayScore;
    const awayWon = isFinished && g.awayScore > g.homeScore;

    grid.innerHTML += `
      <div class="tv-card">
        <div class="tv-league">${g.sport}</div>
        <div class="tv-status">
          ${isLive ? `<div class="live-dot"></div><span class="live-label">${g.info}</span>` : `<span style="color:#555;font-size:11px">${g.info}</span>`}
        </div>
        <div class="tv-teams">
          <div class="tv-team">
            <div class="tv-team-name ${homeWon ? 'winner' : ''}">${g.home}</div>
            <div class="tv-score ${isFinished && !homeWon ? 'faded' : ''}">${g.homeScore ?? '–'}</div>
          </div>
          <div class="tv-team">
            <div class="tv-team-name ${awayWon ? 'winner' : ''}">${g.away}</div>
            <div class="tv-score ${isFinished && !awayWon ? 'faded' : ''}">${g.awayScore ?? '–'}</div>
          </div>
        </div>
      </div>`;
  });

  container.innerHTML = '';
  container.appendChild(grid);
}

// ── TABS ─────────────────────────────────────────────────────────────────────
function switchTab(tab) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById(tab + '-view').classList.add('active');
  event.target.classList.add('active');
}

// ── INIT ─────────────────────────────────────────────────────────────────────
save();
renderPhone();
renderTV();

// Auto-refresh alle 60 Sekunden
setInterval(() => { renderPhone(); renderTV(); }, 60000);
</script>
</body>
</html>
